{
  "$schema": "../gen/schemas/desktop-capability.json",
  "identifier": "default",
  "description": "Permisos core con gestión de archivos",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "opener:default",
    "fs:default",
    "dialog:default",
    "core:window:allow-set-title",
    "core:window:allow-show",
    "core:window:allow-close"
  ]
}